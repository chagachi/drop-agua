# Para scripts/migrate-data.ts (importação direto de um MySQL vivo via service role key)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=transagua
MYSQL_PASSWORD=
MYSQL_DATABASE=transagua

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Para scripts/import-from-dump.mjs (importação a partir de um arquivo .sql,
# autenticado como um usuário admin via API, sem precisar de MySQL vivo nem
# da service role key)
SUPABASE_ANON_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=
DUMP_FILE=caminho/para/dump.sql
